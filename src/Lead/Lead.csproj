<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <PackageId>Lead.Sandbox</PackageId>
    <Version>1.0.0</Version>
    <Authors>Lead Contributors</Authors>
    <Description>A secure, virtualized plugin sandbox for .NET 8. Load third-party assemblies into an isolated environment with static analysis, honeypot virtualization, and resource limits.</Description>
    <PackageTags>sandbox;plugin;security;virtualization;honeypot;isolation</PackageTags>
    <PackageProjectUrl>https://github.com/LeadSandbox/Lead</PackageProjectUrl>
    <RepositoryUrl>https://github.com/LeadSandbox/Lead.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>CS1591</NoWarn>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Castle.Core" Version="5.1.1" />
    <PackageReference Include="Mono.Cecil" Version="0.11.6" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
